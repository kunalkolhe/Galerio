generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password_hash String
  role          String    @default("CLIENT") // "ADMIN", "EDITOR", or "CLIENT"
  profile_image String?
  address       String?
  contact_phone String?
  editor_type   String?
  charges       String?
  bio           String?
  software_used String?
  years_experience String?
  instagram     String?
  youtube       String?
  website       String?
  other_link    String?
  created_at    DateTime  @default(now())
  favorites     Favorite[]
  galleries     Gallery[]
  reviewsGiven  Review[]  @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")
  notifications Notification[]
}

model Gallery {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  price        String?
  before_image String
  after_image  String?
  work_type    String?   @default("Photography") // "Photography" or "Video"
  work_category String?  // e.g. "Wedding", "Cinematic"
  video_url    String?
  category_id  Int?
  category     Category? @relation(fields: [category_id], references: [id])
  created_by   Int
  creator      User      @relation(fields: [created_by], references: [id])
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  favorites    Favorite[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  galleries   Gallery[]
}

model Favorite {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  gallery_id Int
  gallery    Gallery  @relation(fields: [gallery_id], references: [id])

  @@unique([user_id, gallery_id])
}

model ContactMessage {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  message    String
  created_at DateTime @default(now())
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // 1-5 stars
  comment    String?
  client_id  Int
  client     User     @relation("ReviewsGiven", fields: [client_id], references: [id])
  editor_id  Int
  editor     User     @relation("ReviewsReceived", fields: [editor_id], references: [id])
  created_at DateTime @default(now())
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int      // The editor receiving the notification
  user       User     @relation(fields: [user_id], references: [id])
  type       String   // e.g. "HIRE_REQUEST", "GENERAL"
  content    String
  from_name  String?
  from_email String?
  from_phone String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
}
